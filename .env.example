PORT=3000

# GitHub App settings
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# Phase 11 GitHub OAuth and dashboard
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL_SECONDS=28800
DASHBOARD_DEMO_MODE=true

# Phase 9 GitHub review history
MONGODB_URI=
MONGODB_DATABASE=gitsense_ai

# Phase 10 team notifications
NOTIFICATIONS_ENABLED=true
NOTIFICATION_MINIMUM_SEVERITY=HIGH
NOTIFICATION_LOW_CONFIDENCE_THRESHOLD=60
NOTIFICATION_NOTIFY_MEDIUM_RISK=false
NOTIFICATION_MAX_RETRIES=2
NOTIFICATION_TIMEOUT_MS=5000
NOTIFICATION_DEDUPLICATION_TTL_MS=86400000

# Optional catch-all incoming webhooks.
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Route values reference environment-variable names so webhook secrets stay out
# of the JSON configuration. Supported providers: slack, teams.
# NOTIFICATION_ROUTES_JSON={"security":[{"provider":"slack","webhookEnv":"SLACK_SECURITY_WEBHOOK_URL","channel":"security"}],"backend":[{"provider":"teams","webhookEnv":"TEAMS_BACKEND_WEBHOOK_URL","channel":"backend"}],"frontend":[{"provider":"slack","webhookEnv":"SLACK_FRONTEND_WEBHOOK_URL","channel":"frontend"}],"engineering":[{"provider":"teams","webhookEnv":"TEAMS_ENGINEERING_WEBHOOK_URL","channel":"engineering"}]}
SLACK_SECURITY_WEBHOOK_URL=
TEAMS_BACKEND_WEBHOOK_URL=
SLACK_FRONTEND_WEBHOOK_URL=
TEAMS_ENGINEERING_WEBHOOK_URL=

# Phase 3 RAG
# Use local for laptop demos. Use openai or gemini for production-quality embeddings.
RAG_ENABLED=false
RAG_EMBEDDING_PROVIDER=local

# OpenAI embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536

# Gemini embeddings
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_EMBEDDING_TASK_TYPE=SEMANTIC_SIMILARITY

# Phase 5 Gemini AI review
GEMINI_REVIEW_MODEL=gemini-3.5-flash
GEMINI_REVIEW_TEMPERATURE=0.2
GEMINI_REVIEW_MAX_OUTPUT_TOKENS=4096
GEMINI_REVIEW_MAX_RETRIES=2

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
